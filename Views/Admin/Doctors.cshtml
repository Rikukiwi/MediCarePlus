@{
    ViewData["Title"]     = "Quản lý bác sĩ";
    ViewData["AdminPage"] = "Doctors";
    Layout = "_AdminLayout";
    var doctors = ViewBag.Doctors as List<MediCarePlus.Models.Doctor> ?? new List<MediCarePlus.Models.Doctor>();
}

<div class="admin-card">
    <div class="admin-card-header">
        <div class="admin-card-title">Danh sách bác sĩ (@doctors.Count)</div>
    </div>

    <div class="table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Họ và tên</th>
                    <th>Chuyên khoa</th>
                    <th>Bằng cấp</th>
                    <th>Kinh nghiệm</th>
                    <th>Đánh giá</th>
                    <th>Lượt đánh giá</th>
                </tr>
            </thead>
            <tbody>
                @if (!doctors.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align:center;padding:2rem;
                            color:rgba(255,255,255,.3)">
                            Chưa có bác sĩ nào
                        </td>
                    </tr>
                }
                @foreach (var d in doctors)
                {
                    <tr>
                        <td style="color:rgba(255,255,255,.3);font-size:.75rem">
                            @d.Id
                        </td>
                        <td>
                            <div style="display:flex;align-items:center;gap:.75rem">
                                <div style="width:36px;height:36px;border-radius:50%;
                                            background:@d.AvatarBg;color:@d.AvatarFg;
                                            display:flex;align-items:center;
                                            justify-content:center;font-size:.85rem;
                                            font-weight:700;flex-shrink:0">
                                    @d.Initials
                                </div>
                                <span style="color:#fff;font-weight:500">@d.Name</span>
                            </div>
                        </td>
                        <td>
                            <span style="background:@d.AvatarBg;color:@d.AvatarFg;
                                         padding:3px 10px;border-radius:9999px;
                                         font-size:.7rem;font-weight:700">
                                @d.Specialty
                            </span>
                        </td>
                        <td style="color:rgba(255,255,255,.6)">@d.Degree</td>
                        <td style="color:rgba(255,255,255,.6)">@d.Experience năm</td>
                        <td style="color:#F59E0B">&#9733; @d.Rating</td>
                        <td style="color:rgba(255,255,255,.6)">@d.ReviewCount</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>