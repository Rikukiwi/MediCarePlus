<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
    <title>@ViewData["Title"] – Quản trị viên Rau Má+</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css"/>
    <link rel="stylesheet" href="~/css/admin.css"/>
</head>
<body class="admin-body">
<div class="admin-wrap">
    <aside class="admin-sidebar">
        <div class="admin-logo">
            <div class="brand-icon"><svg width="20" height="20" viewBox="0 0 22 22" fill="none"><rect x="9" y="2" width="4" height="18" rx="2" fill="white"/><rect x="2" y="9" width="18" height="4" rx="2" fill="white"/></svg></div>
            <div><div style="color:white;font-weight:900;font-size:18px">MediCare<span style="color:#7DD3FC">+</span></div><div style="color:rgba(255,255,255,.45);font-size:10px;letter-spacing:1px">ADMIN PANEL</div></div>
        </div>
        <nav class="admin-nav">
            <a asp-controller="Admin" asp-action="Index"        class="admin-nav-link @(ViewData["AdminPage"]?.ToString()=="Dashboard"   ?"active":"")"><span class="nav-icon">📊</span> Dashboard</a>
            <a asp-controller="Admin" asp-action="Appointments" class="admin-nav-link @(ViewData["AdminPage"]?.ToString()=="Appointments"?"active":"")"><span class="nav-icon">📋</span> Lịch hẹn</a>
            <a asp-controller="Admin" asp-action="Doctors"      class="admin-nav-link @(ViewData["AdminPage"]?.ToString()=="Doctors"     ?"active":"")"><span class="nav-icon">👨‍⚕️</span> Bác sĩ</a>
            <a asp-controller="Admin" asp-action="Users"        class="admin-nav-link @(ViewData["AdminPage"]?.ToString()=="Users"       ?"active":"")"><span class="nav-icon">👥</span> Người dùng</a>
        </nav>
        <div class="admin-sidebar-bottom">
            <a asp-controller="Home"    asp-action="Index"  class="admin-nav-link">🌐 Xem website</a>
            <a asp-controller="Account" asp-action="Logout" class="admin-nav-link" style="color:#FCA5A5">🚪 Đăng xuất</a>
        </div>
    </aside>
    <main class="admin-main">
        <div class="admin-topbar">
            <h1 class="admin-page-title">@ViewData["Title"]</h1>
            <div class="admin-user-info">
                <div class="admin-avatar">AD</div>
                <div><div style="font-weight:700;font-size:14px;color:var(--text)">@Context.Session.GetString("UserName")</div><div style="font-size:12px;color:var(--gray)">Quản trị viên</div></div>
            </div>
        </div>
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success" style="margin-bottom:24px">
                <div class="alert-icon"><svg width="16" height="16" fill="none" stroke="white" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7"/></svg></div>
                <div><div class="alert-text-body" style="color:#065F46">@TempData["Success"]</div></div>
            </div>
        }
        @RenderBody()
    </main>
</div>
</body>
</html>
